# Copy to config.env and fill in. config.env is gitignored (holds the auth key).
# Plain KEY=value lines; '#' comments. The launcher (.ps1/.sh) and docker
# compose both read this file.

# --- Tailscale --------------------------------------------------------------
# Auth key for the sidecar to join your tailnet. Create one at:
#   https://login.tailscale.com/admin/settings/keys  ("Generate auth key")
# A reusable key is convenient; ephemeral also works. Required.
TS_AUTHKEY=

# MagicDNS hostname for this node. The streaming server ends up at
#   https://<TS_HOSTNAME>.<your-tailnet>.ts.net/
TS_HOSTNAME=stremio

# --- Watching device (documentation only) -----------------------------------
# The tailnet IP (100.x.y.z) of the device that watches via web.stremio.com .
# Not required for the server to run; used in the README's optional Tailscale
# ACL example to lock access down to just this device. Leave blank to skip.
# Example: WATCH_DEVICE_IP=100.101.102.103
WATCH_DEVICE_IP=
